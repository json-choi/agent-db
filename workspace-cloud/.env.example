DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database?sslmode=require
GOOGLE_CLIENT_ID=000000000000-example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000
# Optional invitation delivery. Both must be set; otherwise admins copy the secure link.
RESEND_API_KEY=re_replace-me
WORKSPACE_INVITATION_FROM=DopeDB <workspace@example.com>
