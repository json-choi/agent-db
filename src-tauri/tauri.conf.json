{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DopeDB",
  "version": "0.1.2",
  "identifier": "capital.launcher.dopedb",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm build:bridge && pnpm dev",
    "beforeBuildCommand": "pnpm build:bridge && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "DopeDB",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560,
        "backgroundColor": "#1d1d1f",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "externalBin": ["binaries/dopedb-mcp-stdio"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxRjEwRTY0ODhDODRDNzEKUldSeFRNaUlaQTd4Y1N5Ly8wZ3hNRWZnT2I0RGRBQXBwZzN6NC82NVFMWTlvUkNXWHViMUw1QXQK",
      "endpoints": [
        "https://github.com/json-choi/dopedb/releases/latest/download/latest.json"
      ]
    }
  }
}
