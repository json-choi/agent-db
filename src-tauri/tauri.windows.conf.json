{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "title": "DopeDB",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560,
        "backgroundColor": "#00000000",
        "transparent": true,
        "windowEffects": {
          "effects": ["mica", "acrylic", "blur"],
          "color": "#10141888"
        },
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true
      }
    }
  }
}
