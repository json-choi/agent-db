{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window: core permissions, external links, updater, and process relaunch.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://app.dopedb.dev/auth/device?user_code=*"
        },
        {
          "url": "https://app.dopedb.dev/settings*"
        }
      ]
    },
    "updater:default",
    "process:default"
  ]
}
