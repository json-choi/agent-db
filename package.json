{
  "name": "dopedb",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "vite",
    "build": "pnpm check:ui && tsc && vite build",
    "check:ui": "node scripts/check-ui-depth.mjs",
    "test": "vitest run",
    "workspace:migrate": "bash scripts/migrate-workspace-service.sh",
    "workspace:cloud:dev": "pnpm --dir workspace-cloud dev",
    "workspace:cloud:build": "pnpm --dir workspace-cloud build",
    "build:bridge": "bash scripts/build-bridge.sh",
    "sign:dev": "bash src-tauri/sign-dev.sh",
    "dev:app": "pnpm tauri dev",
    "preview": "vite preview",
    "site:dev": "pnpm --dir site dev",
    "site:build": "pnpm --dir site build",
    "site:preview": "pnpm --dir site start",
    "site:preview-image": "python3 site/scripts/generate-preview.py",
    "icons": "python3 scripts/generate-icons.py",
    "tauri": "bash scripts/tauri.sh"
  },
  "dependencies": {
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@tanstack/react-query": "^5.101.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@uiw/react-codemirror": "^4.25.11",
    "codemirror": "^6.0.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@babel/parser": "8.0.4",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
