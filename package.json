{
  "name": "dopedb",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "build:bridge": "bash scripts/build-bridge.sh",
    "sign:dev": "bash src-tauri/sign-dev.sh",
    "dev:app": "cargo build --manifest-path src-tauri/Cargo.toml && pnpm sign:dev && ./target/debug/dopedb",
    "preview": "vite preview",
    "site:dev": "pnpm --dir site dev",
    "site:build": "pnpm --dir site build",
    "site:preview": "pnpm --dir site start",
    "site:preview-image": "python3 site/scripts/generate-preview.py",
    "icons": "python3 scripts/generate-icons.py",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@uiw/react-codemirror": "^4.23.10",
    "codemirror": "^6.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
