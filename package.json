{
  "name": "dopedb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:bridge": "bash scripts/build-bridge.sh",
    "sign:dev": "bash src-tauri/sign-dev.sh",
    "dev:app": "cargo build --manifest-path src-tauri/Cargo.toml && pnpm sign:dev && ./target/debug/dopedb",
    "preview": "vite preview",
    "site:dev": "pnpm --dir site dev",
    "site:build": "pnpm --dir site build",
    "site:preview": "pnpm --dir site start",
    "site:preview-image": "python3 site/scripts/generate-preview.py",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.4",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@uiw/react-codemirror": "^4.23.10",
    "codemirror": "^6.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
